---
import { experience } from '@/data.json'
---

<section
  id='career'
  class='section border-t border-slate-100 dark:border-slate-900'>
  <div class='wrapper'>
    <div data-reveal>
      <span class='eyebrow'>Werdegang</span>
      <h2 class='section-title'>Erfahrung, die ich mitbringe</h2>
      <p class='section-lead'>
        Über zehn Jahre Erfahrung mit Projekten aus Branchen wie Banken, Sport
        &amp; Events, Industrie und dem öffentlichen Sektor – zuletzt im
        Core-Architecture-Team einer großen Bank. Diese Erfahrung bringe ich
        heute gezielt für kleine und mittlere Unternehmen ein.
      </p>
    </div>

    <ol class='mt-12 space-y-4 border-l border-slate-200 dark:border-slate-800'>
      {
        experience.map((job, i) => (
          <li
            class='relative pl-8'
            data-reveal
            style={`animation-delay:${i * 80}ms`}>
            <span class='absolute -left-[7px] top-6 h-3.5 w-3.5 rounded-full border-2 border-white bg-primary-500 dark:border-slate-950' />
            <div class='card hover:border-primary-300 hover:shadow-lg hover:shadow-primary-900/5 dark:hover:border-primary-700'>
              <div class='flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1'>
                <h3 class='text-lg font-semibold'>{job.role}</h3>
                <span class='text-sm font-medium text-slate-500 dark:text-slate-400'>
                  {job.period}
                </span>
              </div>
              <p class='mt-0.5 text-sm font-medium text-primary-700 dark:text-primary-400'>
                {job.company}
              </p>
              <p class='mt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-400'>
                {job.description}
              </p>
              {job.tags.length > 0 && (
                <ul class='mt-4 flex flex-wrap gap-2'>
                  {job.tags.map(tag => (
                    <li class='rounded-md bg-slate-100 px-2 py-1 text-xs font-medium text-slate-600 dark:bg-slate-800 dark:text-slate-300'>
                      {tag}
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>
