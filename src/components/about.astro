---
import { aboutMe, fullName } from '@/data.json'
import { Image } from 'astro:assets'
import MyPicture from '@/assets/me.png'
---

<section id='about' class='section border-t border-slate-100 dark:border-slate-900'>
  <div class='wrapper grid items-center gap-12 md:grid-cols-2 md:gap-16'>
    <div class='flex justify-center md:justify-start' data-reveal>
      <div class='relative'>
        <div
          class='absolute -inset-4 -z-10 rounded-3xl bg-gradient-to-tr from-primary-500/30 to-primary-300/10 blur-2xl'>
        </div>
        <div
          class='overflow-hidden rounded-3xl border border-slate-200/60 shadow-2xl shadow-primary-900/10 dark:border-slate-800'>
          <Image
            src={MyPicture}
            alt={fullName}
            loading='lazy'
            class='aspect-[4/5] w-60 object-cover object-top sm:w-72'
          />
        </div>
      </div>
    </div>

    <div data-reveal>
      <span class='eyebrow'>Über mich</span>
      <h2 class='section-title'>Erfahrener Fullstack-Entwickler</h2>
      <div class='mt-6 space-y-4 text-lg text-slate-600 dark:text-slate-400'>
        {aboutMe.map(paragraph => <p>{paragraph}</p>)}
      </div>
    </div>
  </div>
</section>
