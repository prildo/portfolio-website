---
import { contact, fullName, metaData, role, skills } from '@/data.json'
import '@/styles/global.css'

const title = `${fullName} – ${role}`
const siteUrl = 'https://dominik-prilmueller.at'

const skillLabels: Record<string, string> = {
  javascript: 'JavaScript',
  postgresql: 'PostgreSQL',
  aws: 'AWS',
  spring: 'Spring Boot',
}

const knowsAbout = skills.map(skill => {
  if (typeof skill !== 'string') return skill.label
  return skillLabels[skill] ?? skill.charAt(0).toUpperCase() + skill.slice(1)
})

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': `${siteUrl}/#person`,
      name: fullName,
      jobTitle: role,
      url: siteUrl,
      email: `mailto:${contact.email}`,
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Linz',
        addressCountry: 'AT',
      },
      knowsAbout,
      sameAs: [contact.social.linkedin, contact.social.github],
    },
    {
      '@type': 'ProfessionalService',
      '@id': `${siteUrl}/#service`,
      name: title,
      description: metaData.description,
      url: siteUrl,
      provider: { '@id': `${siteUrl}/#person` },
      areaServed: { '@type': 'Country', name: 'Österreich' },
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Linz',
        addressCountry: 'AT',
      },
    },
  ],
}
---

<meta charset='utf-8' />
<link rel='icon' type='image/svg+xml' href='/favicon.svg' />
<meta name='viewport' content='width=device-width, initial-scale=1' />
<meta name='generator' content={Astro.generator} />

<title>{title}</title>
<meta name='description' content={metaData.description} />
<meta name='author' content={fullName} />
<meta name='keywords' content={metaData.keywords.join(', ')} />
<link rel='canonical' href={siteUrl} />

<script type='application/ld+json' set:html={JSON.stringify(jsonLd)} />

<meta name='theme-color' content='#020617' />

<!-- Open Graph / social -->
<meta property='og:type' content='website' />
<meta property='og:title' content={title} />
<meta property='og:description' content={metaData.description} />
<meta property='og:url' content={siteUrl} />
<meta name='twitter:card' content='summary_large_image' />
<meta name='twitter:title' content={title} />
<meta name='twitter:description' content={metaData.description} />

<!-- If JS is unavailable, never keep reveal-animated content hidden. -->
<noscript>
  <style>
    [data-reveal] {
      opacity: 1 !important;
    }
  </style>
</noscript>

<!-- Apply the theme before paint to avoid a flash. Dark is the default;
     light only applies when the visitor has explicitly chosen it. -->
<script is:inline>
  if (localStorage.getItem('theme') !== 'light') {
    document.documentElement.classList.add('dark')
  }
</script>
