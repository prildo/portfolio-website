---
import { projects } from '@/data.json'
---

<section id='projects' class='section border-t border-slate-100 dark:border-slate-900'>
  <div class='wrapper'>
    <div data-reveal>
      <span class='eyebrow'>Projekte</span>
      <h2 class='section-title'>Ausgewählte Arbeiten</h2>
      <p class='section-lead'>
        Ein Einblick in Projekte, an denen ich gearbeitet habe. Gerne erzähle
        ich dir im Gespräch mehr über die Details.
      </p>
    </div>

    <div class='mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3'>
      {
        projects.map((project, i) => {
          const Tag = project.link ? 'a' : 'div'
          return (
            <Tag
              {...(project.link
                ? { href: project.link, target: '_blank', rel: 'noopener' }
                : {})}
              class='card group flex flex-col hover:border-primary-300 hover:shadow-lg hover:shadow-primary-900/5 dark:hover:border-primary-700'
              data-reveal
              style={`animation-delay:${i * 80}ms`}>
              <div class='flex items-center justify-between'>
                <span class='inline-block rounded-full bg-primary-50 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-primary-700 dark:bg-primary-950/60 dark:text-primary-400'>
                  {project.category}
                </span>
                {project.link && (
                  <svg
                    xmlns='http://www.w3.org/2000/svg'
                    width='18'
                    height='18'
                    viewBox='0 0 24 24'
                    fill='none'
                    stroke='currentColor'
                    stroke-width='2'
                    stroke-linecap='round'
                    stroke-linejoin='round'
                    class='text-slate-400 transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5 group-hover:text-primary-600'>
                    <path d='M7 17 17 7M7 7h10v10' />
                  </svg>
                )}
              </div>
              <h3 class='mt-4 text-xl font-semibold'>{project.title}</h3>
              <p class='mt-2 flex-1 text-sm leading-relaxed text-slate-600 dark:text-slate-400'>
                {project.description}
              </p>
              <ul class='mt-4 flex flex-wrap gap-2'>
                {project.tags.map(tag => (
                  <li class='rounded-md bg-slate-100 px-2 py-1 text-xs font-medium text-slate-600 dark:bg-slate-800 dark:text-slate-300'>
                    {tag}
                  </li>
                ))}
              </ul>
            </Tag>
          )
        })
      }
    </div>
  </div>
</section>
