---
import { skills } from '@/data.json'
import { Image } from 'astro:assets'
---

<section
  id='technologies'
  class='section border-t border-slate-100 bg-slate-50 dark:border-slate-900 dark:bg-slate-900/30'>
  <div class='wrapper'>
    <div data-reveal>
      <span class='eyebrow'>Technologien</span>
      <h2 class='section-title'>Mein Tech-Stack</h2>
      <p class='section-lead'>
        Werkzeuge und Frameworks, mit denen ich täglich arbeite – von der
        Oberfläche bis zum Betrieb.
      </p>
    </div>

    <div
      class='mt-12 grid grid-cols-3 gap-4 sm:grid-cols-4 lg:grid-cols-6'
      data-reveal>
      {
        skills.map(skill => (
          <div
            title={skill}
            class='card flex flex-col items-center gap-3 p-5 hover:border-primary-300 dark:hover:border-primary-700'>
            <Image
              class='h-12 w-12'
              src={`https://go-skill-icons.vercel.app/api/icons?i=${skill}`}
              loading='lazy'
              width={48}
              height={48}
              alt={skill}
            />
            <span class='text-sm font-medium capitalize text-slate-600 dark:text-slate-400'>
              {skill}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</section>
