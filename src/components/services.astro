---
import { services } from '@/data.json'

// Minimal inline icon set (stroke-based, currentColor).
const icons: Record<string, string> = {
  'app-window':
    '<rect width="18" height="14" x="3" y="5" rx="2"/><path d="M3 9h18M7 7h.01M10 7h.01"/>',
  server:
    '<rect width="20" height="8" x="2" y="3" rx="2"/><rect width="20" height="8" x="2" y="13" rx="2"/><path d="M6 7h.01M6 17h.01"/>',
  cloud:
    '<path d="M17.5 19a4.5 4.5 0 0 0 .5-8.98 6 6 0 0 0-11.64-1.6A4 4 0 0 0 6.5 19h11z"/>',
  refresh:
    '<path d="M21 12a9 9 0 1 1-2.64-6.36"/><path d="M21 3v6h-6"/>',
}
---

<section id='services' class='section'>
  <div class='wrapper'>
    <div data-reveal>
      <span class='eyebrow'>Leistungen</span>
      <h2 class='section-title'>Womit ich dich unterstütze</h2>
      <p class='section-lead'>
        Von der ersten Idee bis zum laufenden Betrieb – ich begleite dein
        Projekt über den gesamten Lebenszyklus.
      </p>
    </div>

    <div class='mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4'>
      {
        services.map((service, i) => (
          <article
            class='card group hover:border-primary-300 hover:shadow-lg hover:shadow-primary-900/5 dark:hover:border-primary-700'
            data-reveal
            style={`animation-delay:${i * 80}ms`}>
            <div class='flex h-12 w-12 items-center justify-center rounded-xl bg-primary-50 text-primary-600 transition-colors group-hover:bg-primary-600 group-hover:text-white dark:bg-primary-950/60 dark:text-primary-400'>
              <svg
                xmlns='http://www.w3.org/2000/svg'
                width='24'
                height='24'
                viewBox='0 0 24 24'
                fill='none'
                stroke='currentColor'
                stroke-width='2'
                stroke-linecap='round'
                stroke-linejoin='round'
                set:html={icons[service.icon] ?? ''}
              />
            </div>
            <h3 class='mt-5 text-lg font-semibold'>{service.title}</h3>
            <p class='mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-400'>
              {service.description}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
